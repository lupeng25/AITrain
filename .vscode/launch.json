        "--server",
        "manual_debug_server"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "C:/Qt/Qt5.12.9/5.12.9/msvc2015_64/bin;${env:PATH}"
        }
      ],
      "console": "integratedTerminal",
      "preLaunchTask": "Build AITrain"
