{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug AITrainStudio",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-vscode/bin/AITrainStudio.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "C:/Qt/Qt5.12.9/5.12.9/msvc2015_64/bin;${env:PATH}"
